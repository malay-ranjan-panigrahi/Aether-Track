pipeline {
    agent any

    environment {
        DOCKER_HUB_USER = 'malaynew07'
        APP_NAME        = 'aether-track'
        IMAGE_TAG       = "v1.0.${env.BUILD_NUMBER}" // Standard versioning
        
        WEATHER_API_KEY = credentials('weather-api-key')
        GEMINI_API_KEY  = credentials('gemini-api-key')
        DOCKER_HUB_CREDS = credentials('docker-hub-creds')
        GITHUB_CREDS    = credentials('github-creds') 
    }

    stages {
        stage('Checkout & Cleanup') {
            steps {
                checkout scm
                sh 'rm -f build_error.log *.tgz' // Clean old packages
            }
        }

        stage('Build & Push Image') {
            steps {
                script {
                    try {
                        sh "docker build -t ${DOCKER_HUB_USER}/${APP_NAME}:${IMAGE_TAG} ."
                        sh "echo ${DOCKER_HUB_CREDS_PSW} | docker login -u ${DOCKER_HUB_CREDS_USR} --password-stdin"
                        sh "docker push ${DOCKER_HUB_USER}/${APP_NAME}:${IMAGE_TAG}"
                    } catch (Exception e) {
                        sh "echo 'BUILD FAILURE' > build_error.log"
                        sh "docker build -t ${DOCKER_HUB_USER}/${APP_NAME}:${IMAGE_TAG} . 2>> build_error.log || true"
                        error("Build failed. AI Agent is analyzing...")
                    }
                }
            }
        }

        stage('Helm Packaging') {
            steps {
                script {
                    // Update Chart.yaml version to match Build Number
                    sh "sed -i 's/^version: .*/version: 0.1.${env.BUILD_NUMBER}/' k8s/aether-app/Chart.yaml"
                    sh "sed -i 's/^appVersion: .*/appVersion: \"${IMAGE_TAG}\"/' k8s/aether-app/Chart.yaml"
                    
                    // Create the .tgz package
                    sh "helm package k8s/aether-app"
                    echo "Helm package created: aether-app-0.1.${env.BUILD_NUMBER}.tgz"
                }
            }
        }

        stage('GitOps Update') {
            steps {
                script {
                    // Update the image tag in values.yaml for ArgoCD
                    sh "sed -i 's/tag: .*/tag: \"${IMAGE_TAG}\"/' k8s/aether-app/values.yaml"
                    
                    sh """
                        git config user.email "malaynew07@gmail.com"
                        git config user.name "malay-ranjan-panigrahi"
                        git add k8s/aether-app/values.yaml k8s/aether-app/Chart.yaml
                        git commit -m "chore: release 0.1.${env.BUILD_NUMBER} [skip ci]"
                    """
                    
                    withCredentials([usernamePassword(credentialsId: 'github-creds', passwordVariable: 'GIT_PASS', usernameVariable: 'GIT_USER')]) {
                        sh "git push https://${GIT_USER}:${GIT_PASS}@github.com/${GIT_USER}/Aether-Track.git HEAD:main"
                    }
                }
            }
        }
    }

    post {
         always {
            echo "Pipeline finished with status: ${currentBuild.currentResult}"
        }
        success {
             echo "✅ Build #${env.BUILD_NUMBER} succeeded — image ${DOCKER_HUB_USER}/${APP_NAME}:${IMAGE_TAG} pushed and GitOps updated."            
        }
        failure {
            sh "/var/lib/jenkins/ai-venv/bin/python cicd/ai_healer.py build_error.log"
        }
        cleanup {
            // removes dangling images (untaged Image).
            sh "docker image prune -f || true"
            // clears the Helm package and error log
            sh "rm -f *.tgz build_error.log || true"
            // wipes the Jenkins workspace
            cleanWs()
        }
    }
}
